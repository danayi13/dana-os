# Copy to .env and fill in real values. .env is gitignored.

# ---- Postgres container superuser (Phase 0) ----
# The postgres image creates this superuser at first boot. Used by
# backend/sql/init.sql to provision the application users.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_me_local_only
POSTGRES_DB=dana_os
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---- Application database users (created by backend/sql/init.sql) ----
DANA_OS_APP_PASSWORD=replace_me_local_only
DANA_OS_RO_PASSWORD=replace_me_local_only

# ---- Backend connection URLs (consumed by pydantic-settings in PR 2) ----
DATABASE_URL=postgresql+psycopg://dana_os_app:replace_me_local_only@localhost:5432/dana_os
DATABASE_URL_RO=postgresql+psycopg://dana_os_ro:replace_me_local_only@localhost:5432/dana_os

# ---- Anthropic / Claude (Phase 12 NLP) ----
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ---- Oura (Phase 7) ----
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
OURA_ACCESS_TOKEN=
OURA_REFRESH_TOKEN=

# ---- Spotify (Phase 11) ----
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# ---- Google (Calendar Phase 10 + Sheets from Phase 1) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_SHEETS_CREDENTIALS_PATH=./secrets/google-sheets-sa.json

# ---- Habits spreadsheet (Phase 1) ----
HABITS_SHEET_ID=
HABITS_SHEET_TAB=

# ---- Vocal lessons spreadsheet (Phase 2) ----
# Sheet ID is in the URL: /spreadsheets/d/<ID>/edit
# Tab name is the label at the bottom of the sheet (not the gid number)
VOCAL_SHEET_ID=
VOCAL_SHEET_TAB=
